color cursor      color15 cyan
color title-focus black   yellow

set main-view = \
    date:display=relative-compact,width=5 \
    author:maxWidth=20 \
    commit-title:graph=v2,refs=true

bind generic y +sh -c 'printf "%s" "$1" | pbcopy && printf "Copied %s to clipboard\\n" "$1"' -- %(commit)

set wrap-search = false
